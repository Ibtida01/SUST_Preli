PORT=8000

# Gemini slow-path routing (LangChain LCEL). Rules engine always runs first.
USE_GEMINI=false
GEMINI_API_KEY=
# gemini-1.5-flash is unavailable on many new API keys; use 2.0 flash tier:
GEMINI_MODEL=gemini-2.0-flash
# Alternatives: gemini-2.5-flash, gemini-flash-latest, gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=4.5
