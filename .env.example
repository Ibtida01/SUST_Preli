# PORT=8000
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# LLM_ENABLED=auto
# LLM_TIMEOUT_SECONDS=3.0
# LLM_CONFIDENCE_THRESHOLD=0.90
# LLM_ALWAYS=false


$env:GEMINI_API_KEY="PASTE_YOUR_GEMINI_KEY_HERE"
$env:GEMINI_MODEL="gemini-1.5-flash"
$env:LLM_ENABLED="auto"
$env:PYTHONPATH="."
.\.venv-win\Scripts\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
